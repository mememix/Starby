# ==================== 数据库配置（必填） ====================
DATABASE_URL="mysql://用户名:密码@数据库地址:端口/数据库名?timezone=%2B08%3A00"
# 示例: DATABASE_URL="mysql://root:StrongPass123@116.204.117.57:3307/ry-cloud?timezone=%2B08%3A00"

# ==================== JWT配置（必填） ====================
# 生产环境请使用随机强密码，可用命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ==================== 服务器配置（必填） ====================
PORT=3001
NODE_ENV=production

# ==================== 短信服务配置（可选，不配置则开发环境下跳过验证码校验） ====================
TENCENT_CLOUD_SECRET_ID=""
TENCENT_CLOUD_SECRET_KEY=""
SMS_APP_ID=""
SMS_TEMPLATE_ID=""
SMS_SIGN_NAME="星护伙伴"

# ==================== 文件上传配置（可选） ====================
UPLOAD_METHOD=http
HTTP_UPLOAD_URL="http://localhost:3001/api/remote-upload"

# ==================== 其他服务（可选） ====================
# Redis（暂未使用，留空即可）
REDIS_URL=""

# 高德地图API Key（后端逆地理编码用，可选）
AMAP_API_KEY=""
