generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId        BigInt    @id @default(autoincrement()) @map("user_id")
  deptId        BigInt?   @map("dept_id")
  userName      String    @map("user_name") @db.VarChar(30)
  nickName      String    @map("nick_name") @db.VarChar(30)
  userType      String?   @default("00") @map("user_type") @db.VarChar(2)
  email         String?   @default("") @db.VarChar(50)
  phonenumber   String?   @default("") @map("phonenumber") @db.VarChar(11)
  sex           String?   @default("0") @db.Char(1)
  avatar        String?   @default("") @db.VarChar(100)
  password      String?   @default("") @db.VarChar(100)
  status        String?   @default("0") @db.Char(1)
  delFlag       String?   @default("0") @map("del_flag") @db.Char(1)
  loginIp       String?   @default("") @map("login_ip") @db.VarChar(128)
  loginDate     DateTime? @map("login_date") @db.DateTime(0)
  pwdUpdateDate DateTime? @map("pwd_update_date") @db.DateTime(0)
  createBy      String?   @default("") @map("create_by") @db.VarChar(64)
  createTime    DateTime? @map("create_time") @db.DateTime(0)
  updateBy      String?   @default("") @map("update_by") @db.VarChar(64)
  updateTime    DateTime? @map("update_time") @db.DateTime(0)
  remark        String?   @db.VarChar(500)

  @@map("sys_user")
}

model Device {
  deviceId         BigInt    @id @default(autoincrement()) @map("device_id")
  deviceCode       String    @unique(map: "uk_device_code") @map("device_code") @db.VarChar(50)
  devicePassword   String?   @default("e10adc3949ba59abbe56e057f20f883e") @map("device_password") @db.VarChar(64)
  bindStatus       Boolean?  @default(false) @map("bind_status")
  userName         String?   @map("user_name") @db.VarChar(100)
  userPhone        String?   @map("user_phone") @db.VarChar(11)
  registerDate     DateTime? @map("register_date") @db.DateTime(0)
  bindDate         DateTime? @map("bind_date") @db.DateTime(0)
  uniqueId         String?   @map("unique_id") @db.VarChar(100)
  locationInfo     String?   @map("location_info") @db.VarChar(500)
  address          String?   @db.VarChar(500)
  longitude        Decimal?  @db.Decimal(10, 6)
  latitude         Decimal?  @db.Decimal(10, 6)
  snCode           String?   @map("sn_code") @db.VarChar(100)
  isTimedReport    Boolean?  @default(false) @map("is_timed_report")
  report_period    Int?
  battery          Int?
  batteryLevel     Int?      @map("battery_level")
  firmwareVersion  String?   @map("firmware_version") @db.VarChar(50)
  deviceName       String?   @map("device_name") @db.VarChar(100)
  deviceType       String?   @map("device_type") @db.VarChar(50)
  deviceModel      String?   @map("device_model") @db.VarChar(50)
  simNumber        String?   @map("sim_number") @db.VarChar(20)
  imei             String?   @db.VarChar(15)
  plateNumber      String?   @map("plate_number") @db.VarChar(20)
  vehicleType      String?   @map("vehicle_type") @db.VarChar(50)
  company          String?   @db.VarChar(200)
  status           String?   @default("0") @db.VarChar(10)
  avatar           String?   @db.Text
  manufacturer     String?   @db.VarChar(100)
  decodeProtocol   String?   @map("decode_protocol") @db.VarChar(50)
  remark           String?   @db.VarChar(500)
  createBy         String?   @default("") @map("create_by") @db.VarChar(64)
  createTime       DateTime? @default(now()) @map("create_time") @db.DateTime(0)
  updateBy         String?   @default("") @map("update_by") @db.VarChar(255)
  updateTime       DateTime? @default(now()) @map("update_time") @db.DateTime(0)
  delFlag          Boolean?  @default(false) @map("del_flag")
  lastLocationTime DateTime? @map("last_location_time") @db.DateTime(0)
  isTop            String?   @default("0") @map("is_top") @db.VarChar(255)

  @@index([bindStatus], map: "idx_bind_status")
  @@index([decodeProtocol], map: "idx_decode_protocol")
  @@index([delFlag], map: "idx_del_flag")
  @@index([imei], map: "idx_imei")
  @@index([manufacturer], map: "idx_manufacturer")
  @@index([registerDate], map: "idx_register_date")
  @@index([simNumber], map: "idx_sim_number")
  @@index([status], map: "idx_status")
  @@index([uniqueId], map: "idx_unique_id")
  @@index([userPhone], map: "idx_user_phone")
  @@map("lot_device")
}

model DeviceBinding {
  bindId     BigInt    @id @default(autoincrement()) @map("bind_id")
