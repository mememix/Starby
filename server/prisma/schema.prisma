  bindTime   DateTime? @default(now()) @map("bind_time") @db.DateTime(0)
  unbindTime DateTime? @map("unbind_time") @db.DateTime(0)
  createTime DateTime? @default(now()) @map("create_time") @db.DateTime(0)
  updateTime DateTime? @default(now()) @map("update_time") @db.DateTime(0)
  remark     String?   @db.VarChar(500)
  isTop      BigInt?   @default(0) @map("is_top")

  @@unique([userId, deviceNo], map: "uk_user_device")
  @@index([bindStatus], map: "idx_bind_status")
  @@index([bindTime], map: "idx_bind_time")
  @@index([deviceId], map: "idx_device_id")
  @@index([deviceNo], map: "idx_device_no")
  @@index([userId], map: "idx_user_id")
  @@map("lot_user_device_bind")
}

